{
  "manifest_version": 3,
  "name": "many-ai-usage",
  "version": "0.1.0",
  "description": "See AI subscription usage in one browser-local dashboard.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "many-ai-usage"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["https://raw.githubusercontent.com/ishizakahiroshi/*"],
  "optional_permissions": ["*://*/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "many-ai-usage@example.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "128": "assets/icons/icon-512.png"
  }
}
